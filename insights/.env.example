# =============================================================================
# Frappe Insights - Environment Variables (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Frappe / Bench Configuration ---
SITE_NAME=insights.local
ADMIN_PASSWORD=admin
PRODUCTION=false

# --- Database (MariaDB / MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=frappe_insights
DB_USER=root
DB_PASSWORD=
DB_TYPE=mariadb

# --- Redis ---
REDIS_CACHE=redis://localhost:6379/1
REDIS_QUEUE=redis://localhost:6379/2
REDIS_SOCKETIO=redis://localhost:6379/3

# --- Development ---
DEV_MODE=1

# --- Encryption ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- SocketIO ---
SOCKETIO_PORT=9000

# --- Email / SMTP ---
MAIL_FROM=insights@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# --- Insights Specific ---
# External data source connections (comma-separated)
INSIGHTS_EXTRA_DATA_SOURCES=
# Query timeout in seconds
INSIGHTS_QUERY_TIMEOUT=300

# --- Backup ---
BACKUP_LIMIT=7
BACKUP_PATH=./backups

# --- CI flag (used internally) ---
CI=false
