# =============================================================================
# Frappe LMS - Environment Variables (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Frappe / Bench Configuration ---
SITE_NAME=lms.local
ADMIN_PASSWORD=admin
PRODUCTION=false

# --- Database (MariaDB / MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=frappe_lms
DB_USER=root
DB_PASSWORD=
DB_TYPE=mariadb

# --- Redis ---
REDIS_CACHE=redis://localhost:6379/1
REDIS_QUEUE=redis://localhost:6379/2
REDIS_SOCKETIO=redis://localhost:6379/3

# --- Development ---
DEV_MODE=1

# --- Encryption ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- SocketIO ---
SOCKETIO_PORT=9000

# --- Email / SMTP ---
MAIL_FROM=lms@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# --- LMS Specific ---
# Enable course creation for non-admin users
LMS_ALLOW_PUBLIC_COURSE_CREATION=false
# Default certificate background image path
LMS_CERTIFICATE_BACKGROUND=/assets/lms/certificate_bg.png
# Third-party video provider (youtube / vimeo / custom)
LMS_VIDEO_PROVIDER=youtube

# --- Backup ---
BACKUP_LIMIT=7
BACKUP_PATH=./backups

# --- CI flag (used internally) ---
CI=false
