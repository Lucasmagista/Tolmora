# =============================================================================
# Frappe Webshop - Environment Variables (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Frappe / Bench Configuration ---
SITE_NAME=webshop.local
ADMIN_PASSWORD=admin
PRODUCTION=false

# --- Database (MariaDB / MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=frappe_webshop
DB_USER=root
DB_PASSWORD=
DB_TYPE=mariadb

# --- Redis ---
REDIS_CACHE=redis://localhost:6379/1
REDIS_QUEUE=redis://localhost:6379/2
REDIS_SOCKETIO=redis://localhost:6379/3

# --- Development ---
DEV_MODE=1

# --- Encryption ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- SocketIO ---
SOCKETIO_PORT=9000

# --- Email / SMTP ---
MAIL_FROM=vendas@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# --- Payment Gateway ---
# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Razorpay (India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Webshop Specific ---
# Shipping provider
WEBSHIPPING_PROVIDER=
# Tax calculation method
WEBSHOP_TAX_METHOD=default
# Currency (ISO 4217)
WEBSHOP_CURRENCY=USD

# --- Backup ---
BACKUP_LIMIT=7
BACKUP_PATH=./backups

# --- CI flag (used internally) ---
CI=false
