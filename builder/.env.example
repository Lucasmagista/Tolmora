# =============================================================================
# Frappe Builder - Environment Variables (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Frappe / Bench Configuration ---
SITE_NAME=builder.local
ADMIN_PASSWORD=admin
PRODUCTION=false

# --- Database (MariaDB / MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=frappe_builder
DB_USER=root
DB_PASSWORD=
DB_TYPE=mariadb

# --- Redis ---
REDIS_CACHE=redis://localhost:6379/1
REDIS_QUEUE=redis://localhost:6379/2
REDIS_SOCKETIO=redis://localhost:6379/3

# --- Development ---
DEV_MODE=1

# --- Encryption ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- SocketIO ---
SOCKETIO_PORT=9000

# --- Email / SMTP ---
MAIL_FROM=builder@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# --- Builder Specific ---
# Domain for published sites
BUILDER_DEFAULT_DOMAIN=example.com
# Storage backend for site assets (local / s3 / azure)
BUILDER_STORAGE_BACKEND=local

# --- Backup ---
BACKUP_LIMIT=7
BACKUP_PATH=./backups

# --- CI flag (used internally) ---
CI=false
