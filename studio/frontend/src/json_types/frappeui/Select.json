{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SelectProps",
  "definitions": {
    "SelectProps": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "stack": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "message",
                "name"
              ]
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "enum": [
            "sm",
            "md",
            "lg",
            "xl"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "subtle",
            "outline",
            "ghost"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "modelValue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "object"
            }
          ]
        },
        "open": {
          "type": "boolean"
        },
        "options": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "object"
                      }
                    ]
                  },
                  "disabled": {
                    "type": "boolean"
                  },
                  "icon": {
                    "type": [
                      "string"
                    ]
                  },
                  "description": {
                    "type": "string"
                  },
                  "slot": {
                    "type": "string"
                  }
                },
                "required": [
                  "label",
                  "value"
                ]
              }
            ]
          }
        },
        "emptyText": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}