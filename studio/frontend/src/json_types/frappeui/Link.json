{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/LinkProps",
  "definitions": {
    "LinkProps": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "stack": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "message",
                "name"
              ]
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "doctype": {
          "type": "string"
        },
        "filters": {
          "type": "object",
          "additionalProperties": {}
        },
        "creatable": {
          "type": "boolean"
        },
        "disabled": {
          "type": "boolean"
        },
        "placeholder": {
          "type": "string"
        }
      },
      "required": [
        "doctype"
      ],
      "additionalProperties": false
    }
  }
}