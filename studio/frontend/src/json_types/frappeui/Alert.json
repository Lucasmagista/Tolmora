{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AlertProps",
  "definitions": {
    "AlertProps": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "theme": {
          "type": "string",
          "enum": [
            "yellow",
            "blue",
            "red",
            "green"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "subtle",
            "outline"
          ]
        },
        "description": {
          "type": "string"
        },
        "dismissible": {
          "type": "boolean"
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false
    }
  }
}