{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CheckboxProps",
  "definitions": {
    "CheckboxProps": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "stack": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "message",
                "name"
              ]
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "enum": [
            "sm",
            "md"
          ]
        },
        "disabled": {
          "type": "boolean"
        },
        "padding": {
          "type": "boolean"
        },
        "modelValue": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "number",
              "const": 1
            },
            {
              "type": "number",
              "const": 0
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}