{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/FormControlProps",
  "definitions": {
    "FormControlProps": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "stack": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "message",
                "name"
              ]
            }
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "date",
            "datetime-local",
            "email",
            "file",
            "month",
            "number",
            "password",
            "search",
            "tel",
            "text",
            "time",
            "url",
            "week",
            "range",
            "textarea",
            "select",
            "checkbox",
            "autocomplete",
            "combobox",
            "multiselect",
            "daterange",
            "datetime"
          ]
        },
        "size": {
          "type": "string",
          "enum": [
            "sm",
            "md"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "subtle",
            "outline"
          ]
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}