{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/TextareaProps",
  "definitions": {
    "TextareaProps": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "stack": {
                  "type": "string"
                },
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false,
              "required": [
                "message",
                "name"
              ]
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "enum": [
            "sm",
            "md",
            "lg",
            "xl"
          ]
        },
        "variant": {
          "type": "string",
          "enum": [
            "subtle",
            "outline",
            "ghost"
          ]
        },
        "placeholder": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "modelValue": {
          "type": "string"
        },
        "debounce": {
          "type": "number"
        },
        "rows": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}