{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CircularProgressBarProps",
  "definitions": {
    "CircularProgressBarProps": {
      "type": "object",
      "properties": {
        "step": {
          "type": "number"
        },
        "totalSteps": {
          "type": "number"
        },
        "showPercentage": {
          "type": "boolean"
        },
        "variant": {
          "type": "string",
          "enum": [
            "solid",
            "outline"
          ]
        },
        "theme": {
          "anyOf": [
            {
              "type": "string",
              "const": "black"
            },
            {
              "type": "string",
              "const": "red"
            },
            {
              "type": "string",
              "const": "green"
            },
            {
              "type": "string",
              "const": "blue"
            },
            {
              "type": "string",
              "const": "orange"
            },
            {
              "type": "object",
              "properties": {
                "primary": {
                  "type": "string"
                },
                "secondary": {
                  "type": "string"
                }
              },
              "required": [
                "primary",
                "secondary"
              ],
              "additionalProperties": false
            }
          ]
        },
        "size": {
          "type": "string",
          "enum": [
            "xs",
            "sm",
            "md",
            "lg",
            "xl"
          ]
        },
        "themeComplete": {
          "type": "string"
        }
      },
      "required": [
        "step",
        "totalSteps"
      ],
      "additionalProperties": false
    }
  }
}